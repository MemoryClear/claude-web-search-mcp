# 生产环境配置示例
# 复制此文件为 .env 并修改

# ============ 必需配置 ============

# API Key（必须设置！使用强随机字符串）
# 生成命令: openssl rand -hex 32
API_KEY=your-strong-random-api-key-here-change-me

# ============ 可选配置 ============

# 服务端口
PORT=3001
HOST=0.0.0.0

# Rate Limit（每 IP 每分钟最大请求数）
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# IP 白名单（逗号分隔，留空则允许所有）
# ALLOWED_IPS=192.168.1.100,10.0.0.0/24

# 强制 HTTPS（需要反向代理配合）
FORCE_HTTPS=false

# CORS（生产环境建议限制来源）
CORS_ENABLED=true
CORS_ORIGIN=*

# ============ 搜索配置（可选）============

# Bing API Key（可选，获得更稳定的搜索）
# BING_API_KEY=your-bing-api-key

# SerpAPI Key（可选，备用）
# SERPAPI_KEY=your-serpapi-key
